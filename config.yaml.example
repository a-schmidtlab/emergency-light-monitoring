# /etc/notlicht-monitor/config.yaml
# Diese Datei ist frei von Passwoertern. Sensible Werte (SMTP-Passwort) stehen
# in einer separaten Datei secrets.yaml im gleichen Verzeichnis - siehe
# secrets.yaml.example und README. Trotzdem: Rechte 600 reicht, die Liste der
# Empfaenger und die Device-URLs sind auch nicht fuer jeden gedacht.

devices:
  - name: "Anlage 1"
    url:  "http://192.0.2.60"
  - name: "Anlage 2"
    url:  "http://192.0.2.61"
  - name: "Anlage 3"
    url:  "http://192.0.2.62"

http:
  timeout_seconds: 10
  retry_attempts: 3
  retry_delays: [10, 30, 60]   # Sekunden zwischen den Versuchen

smtp:
  host: "mail.deinserver.de"
  port: 465
  use_ssl: true              # true = SMTPS (Port 465). false = STARTTLS (Port 587).
  username: "notlicht@deinserver.de"
  # password: hier NICHT eintragen - gehoert nach secrets.yaml.
  from_address: "notlicht@deinserver.de"
  from_name: "Notlicht-Monitor"

recipients:
  - "empfang@example.com"
  - "technik@example.com"

mail:
  # Platzhalter: {status_emoji}, {date}, {device}
  weekly_subject:        "{status_emoji} Wochenreport Notlicht - {date}"
  alarm_subject:         "{status_emoji} ALARM Notlicht - {device}"
  recovery_subject:      "{status_emoji} Entwarnung Notlicht - {device}"
  test_response_subject: "{status_emoji} TEST-Antwort Notlicht - {date}"

  status_emoji_ok:    "🟢"
  status_emoji_fault: "🔴"

  # Standardtext. Wird verwendet, wenn custom_intro_text leer ist.
  # Platzhalter im Text: {date}, {datetime}, {device}
  intro_text: |
    Wochenstatus der Sicherheitsbeleuchtung vom {date}.
    Alle Anlagen wurden automatisch abgefragt. Details unten.

  # Wenn gefuellt: ersetzt intro_text KOMPLETT.
  custom_intro_text: ""

  # Freier Text, wird ans Ende jeder Mail angehaengt. Leer = nichts.
  custom_footer: ""

schedule:
  weekly_report_weekday: 1   # 1=Mo, 2=Di, ..., 7=So (ISO)
  weekly_report_hour: 7      # Stunde 0-23, lokale Zeit

# OPTIONAL: TEST-Mail-Funktion.
# Wer eine Mail mit Subject "TEST" an das Notlicht-Postfach schickt, bekommt
# als Antwort den aktuellen Status der Anlagen zurueck. Andere Mails werden
# stillschweigend geloescht.
#
# WARNUNG: Wenn aktiviert, kann JEDER, der das Postfach kennt, den Status
# abfragen. Pro Lauf bekommt jeder Absender max. 1 Antwort (Reflection-Schutz),
# trotzdem: Adresse nicht oeffentlich verteilen.
imap:
  enabled: false             # auf true setzen, um Funktion zu aktivieren
  host: ""                   # leer = wie smtp.host
  port: 993
  use_ssl: true
  username: ""               # leer = wie smtp.username
  # password: gehoert in secrets.yaml unter imap.password
  #           (leer in secrets.yaml = wie smtp.password)
  folder: "INBOX"
  test_subject: "TEST"       # Subject-Match (case-insensitive, getrimmt)
  delete_processed: true     # alle verarbeiteten Mails aus dem Postfach loeschen
