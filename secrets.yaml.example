# secrets.yaml - enthaelt Passwoerter/Tokens.
# Liegt neben config.yaml im selben Verzeichnis.
# Rechte: chmod 600. Owner: notlicht.
#
# Diese Datei NIEMALS ins Git-Repo committen - sie ist per .gitignore
# ausgeschlossen; nur secrets.yaml.example wird getrackt.
#
# Die Werte hier ueberschreiben beim Start gleichnamige Felder aus config.yaml
# (Deep-Merge, siehe code/config.py).

smtp:
  password: "DEIN_SMTP_PASSWORT_HIER"

# Nur noetig, wenn imap.enabled in der Hauptconfig auf true steht.
# Bei gleichem Account wie SMTP kann der Block weggelassen werden -
# code/config.py uebernimmt dann automatisch smtp.password.
# imap:
#   password: "DEIN_IMAP_PASSWORT_HIER"
